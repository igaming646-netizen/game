# Copy this file to .env and change the secret before deploying for real.
PORT=3001
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
ADMIN_PASSWORD=admin123

# Only needed when deploying to a host with a mounted persistent volume
# (e.g. Railway). Point this at a path INSIDE that volume so save data
# survives redeploys. Leave unset for local development.
# DB_FILE_PATH=/data/db.json
